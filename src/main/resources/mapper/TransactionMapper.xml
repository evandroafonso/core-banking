<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tuum.corebanking.transaction.mapper.TransactionMapper">

    <resultMap id="TransactionResultMap" type="Transaction">
        <id property="id" column="id"/>
        <result property="businessId" column="business_id" javaType="java.util.UUID" jdbcType="OTHER"/>
        <result property="accountId" column="account_id"/>
        <result property="amount" column="amount"/>
        <result property="currency" column="currency" javaType="com.tuum.corebanking.balance.model.Currency"/>
        <result property="direction" column="direction" javaType="com.tuum.corebanking.transaction.model.Direction"/>
        <result property="description" column="description"/>
        <result property="balanceAfter" column="balance_after"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO transactions (business_id, account_id, amount, currency, direction, description, balance_after,
        created_at, updated_at)
        VALUES (
        #{businessId, jdbcType=OTHER},
        #{accountId},
        #{amount},
        #{currency},
        #{direction},
        #{description},
        #{balanceAfter},
        #{createdAt},
        #{updatedAt}
        )
    </insert>

    <select id="findByAccountId" resultMap="TransactionResultMap">
        SELECT id, business_id, account_id, amount, currency, direction, description, balance_after, created_at,
        updated_at
        FROM transactions
        WHERE account_id = #{accountId}
        ORDER BY created_at DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countByAccountId" resultType="long">
        SELECT COUNT(*)
        FROM transactions
        WHERE account_id = #{accountId}
    </select>

</mapper>